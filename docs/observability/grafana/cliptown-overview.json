{
  "uid": "cliptown-overview",
  "title": "Cliptown — overview",
  "description": "P5 Theme D. Imports cleanly into Grafana with the default Prometheus datasource pointing at the world's /metrics endpoint. Panels mirror the metric names defined in crates/world/src/metrics.rs.",
  "tags": ["cliptown"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Tick rate (Hz)",
      "description": "Rate of the loop's tick counter. Production target is 1Hz; sustained <0.5Hz is a stall signal.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "rate(cliptown_tick_seq[1m])", "legendFormat": "ticks/s", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "MCP calls vs errors",
      "description": "Rate of MCP dispatch calls and error subset. A growing error rate (>1/min) usually means an adapter regression.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "rate(cliptown_mcp_calls_total[1m])", "legendFormat": "calls/s", "refId": "A" },
        { "expr": "rate(cliptown_mcp_errors_total[1m])", "legendFormat": "errors/s", "refId": "B" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tasks by status",
      "description": "Current work distribution. Sustained high queued + low in_progress is a scheduler stall; high escalated is operator-actionable.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } } },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value"
      },
      "targets": [
        { "expr": "cliptown_tasks", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Agents by health",
      "description": "P2.1 health buckets. `recently_lost` is a warn; `offline` is an alert (the agent's worker process is gone).",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value"
      },
      "targets": [
        { "expr": "cliptown_agents", "legendFormat": "{{bucket}}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Budget % spent per startup",
      "description": "spent / cap, by startup. Hard pause at 100%; warn band at 80–95% in the cliptown UI.",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1.2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "cliptown_budget_spent_usd / cliptown_budget_cap_usd",
          "legendFormat": "{{startup_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active startups",
      "description": "Currently active startups. Drops imply external pause or all-done.",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "value"
      },
      "targets": [
        { "expr": "cliptown_startups_active", "legendFormat": "active", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cumulative MCP calls",
      "description": "Long-window sanity check that work is happening. Plateau = scheduler stall or no agents online.",
      "gridPos": { "h": 5, "w": 16, "x": 8, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "cliptown_mcp_calls_total", "legendFormat": "calls", "refId": "A" }
      ]
    }
  ]
}
